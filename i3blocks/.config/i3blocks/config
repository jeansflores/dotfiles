separator=true
separator_block_width=15

[systemctl]
command=$SCRIPT_DIR/systemctl/systemctl
interval=once
markup=pango
instance=docker

[cpu_usage]
command=$SCRIPT_DIR/cpu_usage/cpu_usage
interval=10
LABEL=cpu 
DECIMALS=0
COLOR_NORMAL=#EBDBB2
COLOR_WARN=#FFFC00
COLOR_CRIT=#FF0000

[memory]
command=$SCRIPT_DIR/memory/memory
label=men 
interval=30

[volume]
command=$SCRIPT_DIR/volume/volume
LABEL=vol 
interval=once
signal=10

[battery]
command=$SCRIPT_DIR/battery/battery
interval=30
LABEL=bat 

[calendar]
command=$SCRIPT_DIR/calendar/calendar
interval=1
LABEL=’ü│ 
DATEFMT=+%H:%M:%S
HEIGHT=180
WIDTH=220

[user]
label=’Ćć 
command=lslogins | grep $USER | awk '{print $5}'
interval=once

[dunst]
command=$SCRIPT_DIR/dunst/dunst
interval=once
format=json
markup=pango
#min_width=50
#align=center