command=/usr/lib/i3blocks/$BLOCK_NAME/$BLOCK_NAME
separator=true
separator_block_width=15

[cpu_usage]
command=/usr/lib/i3blocks/cpu_usage/cpu_usage
interval=10
LABEL=cpu:
DECIMALS=0
COLOR_NORMAL=#EBDBB2
COLOR_WARN=#FFFC00
COLOR_CRIT=#FF0000

[memory]
command=/usr/lib/i3blocks/memory/memory
label=mem:
interval=30

# [volume]
# command=/usr/lib/i3blocks/volume/volume
# LABEL=vol:
# interval=once
# signal=10

[battery]
command=/usr/lib/i3blocks/battery/battery
interval=30
LABEL=bat:

[calendar]
command=/usr/lib/i3blocks/calendar/calendar
interval=1
LABEL=
DATEFMT=+%H:%M:%S
HEIGHT=180
WIDTH=220

[user]
label=
command=lslogins | grep $USER | awk '{print $2}'
interval=once

[dunst]
command=/usr/lib/i3blocks/dunst/dunst
interval=once
format=json
markup=pango
