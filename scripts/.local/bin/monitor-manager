#!/usr/bin/env bash
#
# monitor-manager — gerencia modos de display para laptop + monitor externo
#
# Uso:
#   monitor-manager mirror    → toggle espelho (mirror ↔ estendido)
#   monitor-manager external  → toggle externo only (desliga laptop, liga só externo ↔ estendido)
#   monitor-manager extend    → modo estendido
#   monitor-manager auto      → ativa estendido se externo conectado, interno se não
#
# Outputs:
#   INTERNAL = eDP
#   EXTERNAL = HDMI-A-0

INTERNAL="eDP"
EXTERNAL="HDMI-A-0"

external_connected() {
    xrandr --query | grep -q "^${EXTERNAL} connected"
}

external_active() {
    xrandr --query | grep "^${EXTERNAL}" | grep -q "[0-9]\+x[0-9]\++"
}

internal_active() {
    xrandr --query | grep "^${INTERNAL}" | grep -q "[0-9]\+x[0-9]\++"
}

is_mirror() {
    external_active && internal_active && \
    xrandr --query | grep "^${EXTERNAL}" | grep -q "+0+0" && \
    xrandr --query | grep "^${INTERNAL}" | grep -q "+0+0"
}

is_external_only() {
    external_active && ! internal_active
}

notify() {
    notify-send "Monitor" "$1" 2>/dev/null || true
}

mode_extend() {
    xrandr \
        --output "$INTERNAL" --auto --primary \
        --output "$EXTERNAL" --auto --right-of "$INTERNAL"
    notify "Modo estendido ativado"
}

mode_mirror() {
    local res
    res=$(xrandr --query | grep "^${INTERNAL}" | grep -oP '\d+x\d+' | head -1)
    xrandr \
        --output "$INTERNAL" --auto --primary \
        --output "$EXTERNAL" --same-as "$INTERNAL" --scale-from "$res"
    notify "Modo espelho ativado"
}

mode_internal_only() {
    xrandr \
        --output "$INTERNAL" --auto --primary \
        --output "$EXTERNAL" --off
    notify "Somente tela interna"
}

mode_external_only() {
    xrandr \
        --output "$EXTERNAL" --auto --primary \
        --output "$INTERNAL" --off
    notify "Somente monitor externo (laptop pode ser fechado)"
}

reload_polybar() {
    sleep 0.5
    ~/.config/polybar/launch.sh
}

case "$1" in
    mirror)
        if is_mirror; then
            mode_extend
        elif external_connected; then
            mode_mirror
        else
            notify "Nenhum monitor externo conectado"
        fi
        reload_polybar
        ;;

    external)
        if is_external_only; then
            mode_extend
            reload_polybar
        elif external_connected; then
            mode_external_only
            reload_polybar
        else
            notify "Nenhum monitor externo conectado"
        fi
        ;;

    extend)
        mode_extend
        reload_polybar
        ;;

    auto)
        if external_connected; then
            if ! external_active; then
                mode_extend
                reload_polybar
            fi
        else
            if ! internal_active; then
                mode_internal_only
                reload_polybar
            fi
        fi
        ;;
esac
